{
  "name": "cuda-toolkit",
  "type": "module",
  "version": "0.2.30",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "description": "GitHub Action to install the NVIDIA CUDA Toolkit",
  "author": "Jim Verheijde",
  "license": "MIT",
  "homepage": "https://github.com/MZWNET/cuda-toolkit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MZWNET/cuda-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/MZWNET/cuda-toolkit/issues"
  },
  "keywords": [
    "actions",
    "cuda",
    "cuda-toolkit",
    "github-actions",
    "nvidia",
    "toolkit"
  ],
  "exports": {
    ".": "./dist/index.cjs"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "all": "pnpm run lint && pnpm run typecheck && pnpm run knip && pnpm run test && pnpm run coverage && pnpm run build",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.cjs --tree-shaking=true --minify --sourcemap --tsconfig=tsconfig.build.json",
    "build:watch": "pnpm run build --watch",
    "coverage": "make-coverage-badge --output-path ./badges/coverage.svg",
    "knip": "knip",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit",
    "update-links": "pnpm --filter @cuda-toolkit/update-links start"
  },
  "dependencies": {
    "@actions/artifact": "^6.2.1",
    "@actions/cache": "^6.0.1",
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0",
    "@types/semver": "^7.7.1",
    "semver": "^7.8.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^25.9.3",
    "@typescript/native-preview": "7.0.0-dev.20260613.1",
    "@vitest/coverage-v8": "^4.1.8",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-format": "^2.0.1",
    "jiti": "^2.7.0",
    "knip": "^6.16.1",
    "make-coverage-badge": "^1.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
