{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["vitest/globals"],
    "allowJs": true,
    "noEmit": true
  },
  "include": [
    "__fixtures__/**/*.ts",
    "tests/**/*.ts",
    "src/**/*.ts",
    "eslint.config.ts",
    "vitest.config.ts",
    "rollup.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
